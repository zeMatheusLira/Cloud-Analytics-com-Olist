<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>-1</pipeline_status>
    <parameters/>
    <name>pip_dim_categoria</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/06/27 00:00:00.000</created_date>
    <modified_date>2026/06/27 00:00:00.000</modified_date>
  </info>
  <!-- Lê product_category_name_translation.csv -->
  <transform>
    <type>CSVInput</type>
    <name>Ler CSV Traducao Categoria</name>
    <filename>${PROJECT_HOME}/datasets/product_category_name_translation.csv</filename>
    <include_filename>N</include_filename>
    <rownum_field/>
    <header>Y</header>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <encoding/>
    <newline_possible>N</newline_possible>
    <schemaDefinition/>
    <ignoreFields>N</ignoreFields>
    <fields>
      <field>
        <name>product_category_name</name>
        <length>50</length>
        <type>String</type>
        <format/>
        <trim_type>both</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
      <field>
        <name>product_category_name_english</name>
        <length>50</length>
        <type>String</type>
        <format/>
        <trim_type>both</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>144</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Sequence</type>
    <name>Gerar SK Categoria</name>
    <valuename>sk_categoria</valuename>
    <use_database>N</use_database>
    <connection>supabase-olist</connection>
    <schema/>
    <seqname>SEQ_</seqname>
    <use_counter>Y</use_counter>
    <counter_name/>
    <start_at>1</start_at>
    <increment_by>1</increment_by>
    <max_value>999999999</max_value>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>320</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>TableOutput</type>
    <name>Gravar dim_categoria</name>
    <connection>supabase-olist</connection>
    <schema/>
    <table>dim_categoria</table>
    <commit>5000</commit>
    <truncate>N</truncate>
    <only_when_have_rows>N</only_when_have_rows>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <specify_fields>Y</specify_fields>
    <auto_update_table_structure>N</auto_update_table_structure>
    <fields>
      <field>
        <stream_name>sk_categoria</stream_name>
        <column_name>sk_categoria</column_name>
      </field>
      <field>
        <stream_name>product_category_name</stream_name>
        <column_name>nome_categoria_pt</column_name>
      </field>
      <field>
        <stream_name>product_category_name_english</stream_name>
        <column_name>nome_categoria_en</column_name>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>496</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>Ler CSV Traducao Categoria</from>
      <to>Gerar SK Categoria</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Gerar SK Categoria</from>
      <to>Gravar dim_categoria</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads/>
  <attributes/>
  <transform_error_handling/>
</pipeline>
