<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>-1</pipeline_status>
    <parameters/>
    <name>pip_fato_reviews</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/06/27 00:00:00.000</created_date>
    <modified_date>2026/06/27 00:00:00.000</modified_date>
  </info>
  <transform>
    <type>CSVInput</type>
    <name>Ler CSV Reviews</name>
    <filename>${PROJECT_HOME}/datasets/olist_order_reviews_dataset.csv</filename>
    <include_filename>N</include_filename>
    <rownum_field/>
    <header>Y</header>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <encoding>UTF-8</encoding>
    <newline_possible>Y</newline_possible>
    <schemaDefinition/>
    <ignoreFields>N</ignoreFields>
    <fields>
      <field>
        <name>review_id</name>
        <length>32</length>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
      <field>
        <name>order_id</name>
        <length>32</length>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
      <field>
        <name>review_score</name>
        <length>1</length>
        <type>Integer</type>
        <format>#</format>
        <trim_type>none</trim_type>
        <precision>0</precision>
        <currency>$</currency>
        <decimal>,</decimal>
        <group>.</group>
      </field>
      <field>
        <name>review_comment_title</name>
        <length>100</length>
        <type>String</type>
        <format/>
        <trim_type>both</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
      <field>
        <name>review_comment_message</name>
        <length>500</length>
        <type>String</type>
        <format/>
        <trim_type>both</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
      <field>
        <name>review_creation_date</name>
        <length>-1</length>
        <type>Date</type>
        <format>yyyy-MM-dd HH:mm:ss</format>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>,</decimal>
        <group>.</group>
      </field>
      <field>
        <name>review_answer_timestamp</name>
        <length>-1</length>
        <type>Date</type>
        <format>yyyy-MM-dd HH:mm:ss</format>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>,</decimal>
        <group>.</group>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>160</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Calculator</type>
    <name>Extrair Data Review</name>
    <calculation>
      <field_name>ano_review</field_name>
      <calc_type>YEAR_OF_DATE</calc_type>
      <field_a>review_creation_date</field_a>
      <field_b/>
      <field_c/>
      <value_type>Integer</value_type>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <conversion_mask/>
      <decimal_symbol/>
      <grouping_symbol/>
      <currency_symbol/>
      <remove>N</remove>
    </calculation>
    <calculation>
      <field_name>mes_review</field_name>
      <calc_type>MONTH_OF_DATE</calc_type>
      <field_a>review_creation_date</field_a>
      <field_b/>
      <field_c/>
      <value_type>Integer</value_type>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <conversion_mask/>
      <decimal_symbol/>
      <grouping_symbol/>
      <currency_symbol/>
      <remove>N</remove>
    </calculation>
    <calculation>
      <field_name>dia_review</field_name>
      <calc_type>DAY_OF_MONTH</calc_type>
      <field_a>review_creation_date</field_a>
      <field_b/>
      <field_c/>
      <value_type>Integer</value_type>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <conversion_mask/>
      <decimal_symbol/>
      <grouping_symbol/>
      <currency_symbol/>
      <remove>N</remove>
    </calculation>
    <failIfNoFile>Y</failIfNoFile>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>320</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Janino</type>
    <name>Gerar SK Tempo Review</name>
    <formula>
      <field_name>sk_tempo_review</field_name>
      <formula_string>(ano_review != null &amp;&amp; mes_review != null &amp;&amp; dia_review != null) ? (ano_review * 10000 + mes_review * 100 + dia_review) : -1</formula_string>
      <value_type>Integer</value_type>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <replace_field/>
    </formula>
    <java_target_version>6</java_target_version>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>480</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>TableOutput</type>
    <name>Gravar fato_reviews</name>
    <connection>supabase-olist</connection>
    <schema/>
    <table>fato_reviews</table>
    <commit>10000</commit>
    <truncate>N</truncate>
    <only_when_have_rows>N</only_when_have_rows>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <specify_fields>Y</specify_fields>
    <auto_update_table_structure>N</auto_update_table_structure>
    <fields>
      <field>
        <stream_name>review_id</stream_name>
        <column_name>review_id</column_name>
      </field>
      <field>
        <stream_name>order_id</stream_name>
        <column_name>order_id</column_name>
      </field>
      <field>
        <stream_name>review_score</stream_name>
        <column_name>nota_review</column_name>
      </field>
      <field>
        <stream_name>review_comment_title</stream_name>
        <column_name>titulo_comentario</column_name>
      </field>
      <field>
        <stream_name>review_comment_message</stream_name>
        <column_name>mensagem_comentario</column_name>
      </field>
      <field>
        <stream_name>sk_tempo_review</stream_name>
        <column_name>sk_tempo_review</column_name>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>640</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>Ler CSV Reviews</from>
      <to>Extrair Data Review</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Data Review</from>
      <to>Gerar SK Tempo Review</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Gerar SK Tempo Review</from>
      <to>Gravar fato_reviews</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads/>
  <attributes/>
  <transform_error_handling/>
</pipeline>
