  <transform>
    <type>Janino</type>
    <name>User defined Java expression</name>
    <formula>
      <field_name>sk_tempo_pedido_final</field_name>
      <formula_string>(ano_p != null &amp;&amp; mes_p != null &amp;&amp; dia_p != null) ? (ano_p * 10000 + mes_p * 100 + dia_p) : -1</formula_string>
      <value_type>Integer</value_type>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <replace_field/>
    </formula>
    <formula>
      <field_name>sk_tempo_entrega_final</field_name>
      <formula_string>(ano_e != null &amp;&amp; mes_e != null &amp;&amp; dia_e != null) ? (ano_e * 10000 + mes_e * 100 + dia_e) : -1</formula_string>
      <value_type>Integer</value_type>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <replace_field/>
    </formula>
    <formula>
      <field_name>dias_atraso_entrega</field_name>
      <formula_string>(order_delivered_customer_date != null &amp;&amp; order_estimated_delivery_date != null) ? (int)((order_delivered_customer_date.getTime() - order_estimated_delivery_date.getTime()) / 86400000L) : null</formula_string>
      <value_type>Integer</value_type>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <replace_field/>
    </formula>
    <java_target_version>6</java_target_version>
