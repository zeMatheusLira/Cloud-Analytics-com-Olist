<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>-1</pipeline_status>
    <parameters/>
    <name>pip_fato_pagamentos</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/06/27 00:00:00.000</created_date>
    <modified_date>2026/06/27 00:00:00.000</modified_date>
  </info>
  <transform>
    <type>CSVInput</type>
    <name>Ler CSV Pagamentos</name>
    <filename>${PROJECT_HOME}/datasets/olist_order_payments_dataset.csv</filename>
    <include_filename>N</include_filename>
    <rownum_field/>
    <header>Y</header>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <encoding/>
    <newline_possible>N</newline_possible>
    <schemaDefinition/>
    <ignoreFields>N</ignoreFields>
    <fields>
      <field>
        <name>order_id</name>
        <length>32</length>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
      <field>
        <name>payment_sequential</name>
        <length>5</length>
        <type>Integer</type>
        <format>#</format>
        <trim_type>none</trim_type>
        <precision>0</precision>
        <currency>$</currency>
        <decimal>,</decimal>
        <group>.</group>
      </field>
      <field>
        <name>payment_type</name>
        <length>20</length>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
      <field>
        <name>payment_installments</name>
        <length>5</length>
        <type>Integer</type>
        <format>#</format>
        <trim_type>none</trim_type>
        <precision>0</precision>
        <currency>$</currency>
        <decimal>,</decimal>
        <group>.</group>
      </field>
      <field>
        <name>payment_value</name>
        <length>15</length>
        <type>Number</type>
        <format>#.##</format>
        <trim_type>none</trim_type>
        <precision>2</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>160</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>TableOutput</type>
    <name>Gravar fato_pagamentos</name>
    <connection>supabase-olist</connection>
    <schema/>
    <table>fato_pagamentos</table>
    <commit>10000</commit>
    <truncate>N</truncate>
    <only_when_have_rows>N</only_when_have_rows>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <specify_fields>Y</specify_fields>
    <auto_update_table_structure>N</auto_update_table_structure>
    <fields>
      <field>
        <stream_name>order_id</stream_name>
        <column_name>order_id</column_name>
      </field>
      <field>
        <stream_name>payment_sequential</stream_name>
        <column_name>sequencial_pagamento</column_name>
      </field>
      <field>
        <stream_name>payment_type</stream_name>
        <column_name>tipo_pagamento</column_name>
      </field>
      <field>
        <stream_name>payment_installments</stream_name>
        <column_name>parcelas</column_name>
      </field>
      <field>
        <stream_name>payment_value</stream_name>
        <column_name>valor_pagamento</column_name>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>400</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>Ler CSV Pagamentos</from>
      <to>Gravar fato_pagamentos</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads/>
  <attributes/>
  <transform_error_handling/>
</pipeline>
