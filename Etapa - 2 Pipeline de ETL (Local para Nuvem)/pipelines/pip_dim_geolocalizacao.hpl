<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>-1</pipeline_status>
    <parameters/>
    <name>pip_dim_geolocalizacao</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/06/27 00:00:00.000</created_date>
    <modified_date>2026/06/27 00:00:00.000</modified_date>
  </info>
  <transform>
    <type>CSVInput</type>
    <name>Ler CSV Geolocalizacao</name>
    <filename>${PROJECT_HOME}/datasets/olist_geolocation_dataset.csv</filename>
    <include_filename>N</include_filename>
    <rownum_field/>
    <header>Y</header>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <encoding/>
    <newline_possible>N</newline_possible>
    <schemaDefinition/>
    <ignoreFields>N</ignoreFields>
    <fields>
      <field>
        <name>geolocation_zip_code_prefix</name>
        <length>5</length>
        <type>Integer</type>
        <format>#</format>
        <trim_type>none</trim_type>
        <precision>0</precision>
        <currency>$</currency>
        <decimal>,</decimal>
        <group>.</group>
      </field>
      <field>
        <name>geolocation_lat</name>
        <length>15</length>
        <type>Number</type>
        <format>#.#</format>
        <trim_type>none</trim_type>
        <precision>6</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
      <field>
        <name>geolocation_lng</name>
        <length>15</length>
        <type>Number</type>
        <format>#.#</format>
        <trim_type>none</trim_type>
        <precision>6</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
      <field>
        <name>geolocation_city</name>
        <length>50</length>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
      <field>
        <name>geolocation_state</name>
        <length>2</length>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>144</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>SortRows</type>
    <name>Ordenar por CEP</name>
    <sort_size>1000000</sort_size>
    <free_memory_treshold>25</free_memory_treshold>
    <compress>N</compress>
    <compress_variable/>
    <prefix>out</prefix>
    <directory>${java.io.tmpdir}</directory>
    <only_passing_unique_rows>N</only_passing_unique_rows>
    <fields>
      <field>
        <name>geolocation_zip_code_prefix</name>
        <ascending>Y</ascending>
        <case_sensitive>N</case_sensitive>
      </field>
      <field>
        <name>geolocation_lat</name>
        <ascending>Y</ascending>
        <case_sensitive>N</case_sensitive>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>304</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Unique</type>
    <name>Remover Duplicatas de CEP</name>
    <count_rows>N</count_rows>
    <count_field/>
    <reject_duplicate_row>N</reject_duplicate_row>
    <error_description/>
    <fields>
      <field>
        <name>geolocation_zip_code_prefix</name>
        <case_insensitive>N</case_insensitive>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>464</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Sequence</type>
    <name>Gerar SK Geo</name>
    <valuename>sk_geo</valuename>
    <use_database>N</use_database>
    <connection>supabase-olist</connection>
    <schema/>
    <seqname>SEQ_</seqname>
    <use_counter>Y</use_counter>
    <counter_name/>
    <start_at>1</start_at>
    <increment_by>1</increment_by>
    <max_value>999999999</max_value>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>624</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>TableOutput</type>
    <name>Gravar dim_geolocalizacao</name>
    <connection>supabase-olist</connection>
    <schema/>
    <table>dim_geolocalizacao</table>
    <commit>10000</commit>
    <truncate>N</truncate>
    <only_when_have_rows>N</only_when_have_rows>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <specify_fields>Y</specify_fields>
    <auto_update_table_structure>N</auto_update_table_structure>
    <fields>
      <field>
        <stream_name>sk_geo</stream_name>
        <column_name>sk_geo</column_name>
      </field>
      <field>
        <stream_name>geolocation_zip_code_prefix</stream_name>
        <column_name>cep_prefixo</column_name>
      </field>
      <field>
        <stream_name>geolocation_lat</stream_name>
        <column_name>latitude</column_name>
      </field>
      <field>
        <stream_name>geolocation_lng</stream_name>
        <column_name>longitude</column_name>
      </field>
      <field>
        <stream_name>geolocation_city</stream_name>
        <column_name>cidade</column_name>
      </field>
      <field>
        <stream_name>geolocation_state</stream_name>
        <column_name>estado</column_name>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>784</xloc>
      <yloc>176</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>Ler CSV Geolocalizacao</from>
      <to>Ordenar por CEP</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Ordenar por CEP</from>
      <to>Remover Duplicatas de CEP</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Remover Duplicatas de CEP</from>
      <to>Gerar SK Geo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Gerar SK Geo</from>
      <to>Gravar dim_geolocalizacao</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads/>
  <attributes/>
  <transform_error_handling/>
</pipeline>
